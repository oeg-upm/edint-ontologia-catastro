  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasPropertyReference">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has property reference</rdfs:label>
    <rdfs:label xml:lang="es">tiene referencia de inmueble</rdfs:label>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
    <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/PropertyReference"/>
    <rdfs:comment xml:lang="en">Relationship linking a cadastral property to its property reference.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relación que vincula un inmueble catastral con su referencia de inmueble.</rdfs:comment>
    <owl:inverseOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/propertyReferenceFor"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/constructionYear">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">construction year</rdfs:label>
    <rdfs:label xml:lang="es">año de construcción</rdfs:label>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
    <rdfs:comment xml:lang="en">Year in which the building was constructed.</rdfs:comment>
    <rdfs:comment xml:lang="es">Año en que se construyó el edificio.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/propertyReference">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">property reference</rdfs:label>
    <rdfs:label xml:lang="es">referencia de inmueble</rdfs:label>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/PropertyReference"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">The property reference part including check digit. Format: alphanumeric with check (e.g., TF8006N0001HZ).</rdfs:comment>
    <rdfs:comment xml:lang="es">La parte de referencia de inmueble incluyendo dígito de control. Formato: alfanumérico con control (ej. TF8006N0001HZ).</rdfs:comment>
    <rdfs:seeAlso rdf:resource="https://www.sedecatastro.gob.es"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n0c54e936ab814760b5a795086612e401b1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasParcelReference"/>
    <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
    <owl:onClass rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/ParcelReference"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/Renovation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Renovation</rdfs:label>
    <rdfs:label xml:lang="es">Reforma</rdfs:label>
    <rdfs:comment xml:lang="en">Event or process of renovating a construction, including information about when it occurred and what type of renovation was performed.</rdfs:comment>
    <rdfs:comment xml:lang="es">Evento o proceso de reforma de una construcción, incluyendo información sobre cuándo ocurrió y qué tipo de reforma se realizó.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n0c54e936ab814760b5a795086612e401b21">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
    <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/clase"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n0c54e936ab814760b5a795086612e401b3">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasPropertyReference"/>
    <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
    <owl:onClass rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/PropertyReference"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasParcelReference">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has parcel reference</rdfs:label>
    <rdfs:label xml:lang="es">tiene referencia de parcela</rdfs:label>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralParcel"/>
    <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/ParcelReference"/>
    <rdfs:comment xml:lang="en">Relationship linking a cadastral parcel to its parcel reference.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relación que vincula una parcela catastral con su referencia de parcela.</rdfs:comment>
    <owl:inverseOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/parcelReferenceFor"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n0c54e936ab814760b5a795086612e401b2">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://www.opengis.net/ont/geosparql#hasGeometry"/>
    <owl:someValuesFrom rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Cadastral Construction</rdfs:label>
    <rdfs:label xml:lang="es">Construcción Catastral</rdfs:label>
    <rdfs:comment xml:lang="en">Building or construction registered on a cadastral property. Includes data on area, use, construction characteristics, and renovations. A cadastral construction is located on exactly one cadastral property.</rdfs:comment>
    <rdfs:comment xml:lang="es">Edificio o construcción registrada sobre un inmueble catastral. Incluye datos de superficie, uso, características constructivas y reformas. Una construcción catastral está ubicada sobre un único inmueble catastral.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
    <rdfs:subClassOf rdf:nodeID="n0c54e936ab814760b5a795086612e401b6"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasHorizontalDivision">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">has horizontal division</rdfs:label>
    <rdfs:label xml:lang="es">tiene división horizontal</rdfs:label>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:comment xml:lang="en">Boolean indicating whether a cadastral property is subject to horizontal division regime.</rdfs:comment>
    <rdfs:comment xml:lang="es">Booleano que indica si un inmueble catastral está sujeto a régimen de división horizontal.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n0c54e936ab814760b5a795086612e401b4">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
