<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:qudt="http://qudt.org/schema/qudt/"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:vann="http://purl.org/vocab/vann/"
>
  <rdf:Description rdf:nodeID="n0c54e936ab814760b5a795086612e401b9">
    <rdf:first rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralParcel"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralParcel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Cadastral Parcel</rdfs:label>
    <rdfs:label xml:lang="es">Parcela Catastral</rdfs:label>
    <rdfs:comment xml:lang="en">Basic unit of territorial division in the Spanish Cadastre. Represents a plot of land delimited geographically, which may contain one or more properties.</rdfs:comment>
    <rdfs:comment xml:lang="es">Unidad básica de división territorial en el Catastro Español. Representa una porción de terreno delimitada geográficamente, que puede contener uno o más inmuebles.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
    <rdfs:subClassOf rdf:nodeID="n0c54e936ab814760b5a795086612e401b1"/>
    <rdfs:subClassOf rdf:nodeID="n0c54e936ab814760b5a795086612e401b2"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/PropertyReference">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralReference"/>
    <rdfs:label xml:lang="en">Property Reference</rdfs:label>
    <rdfs:label xml:lang="es">Referencia de Inmueble</rdfs:label>
    <rdfs:comment xml:lang="en">Reference identifying a cadastral property, composed of the parcel reference and the property reference with check digit (e.g., TF8006N0001HZ).</rdfs:comment>
    <rdfs:comment xml:lang="es">Referencia que identifica un inmueble catastral, compuesta por la referencia de parcela y la referencia de inmueble con dígito de control (ej. TF8006N0001HZ).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasCadastralProperty">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has cadastral property</rdfs:label>
    <rdfs:label xml:lang="es">tiene inmueble catastral</rdfs:label>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralParcel"/>
    <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
    <rdfs:comment xml:lang="en">Relationship indicating that a cadastral parcel contains one or more cadastral properties (e.g., flats in a horizontal division).</rdfs:comment>
    <rdfs:comment xml:lang="es">Relación que indica que una parcela catastral contiene uno o más inmuebles catastrales (ej. pisos en una división horizontal).</rdfs:comment>
    <owl:inverseOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/onCadastralParcel"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/renovationType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">renovation type</rdfs:label>
    <rdfs:label xml:lang="es">tipo de reforma</rdfs:label>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/Renovation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">Type of renovation performed.</rdfs:comment>
    <rdfs:comment xml:lang="es">Tipo de reforma realizada.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/onCadastralParcel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">on cadastral parcel</rdfs:label>
    <rdfs:label xml:lang="es">sobre parcela catastral</rdfs:label>
    <rdfs:comment xml:lang="en">Relationship indicating that a cadastral property is located on exactly one cadastral parcel.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relación que indica que un inmueble catastral está ubicado sobre una única parcela catastral.</rdfs:comment>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
    <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralParcel"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/supportPercentage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">support percentage</rdfs:label>
    <rdfs:label xml:lang="es">porcentaje de soporte</rdfs:label>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <qudt:unit rdf:resource="http://qudt.org/vocab/unit/PCT"/>
    <rdfs:comment xml:lang="en">Percentage of the construction area that is considered support area (common elements).</rdfs:comment>
    <rdfs:comment xml:lang="es">Porcentaje del área de construcción que se considera área de soporte (elementos comunes).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Cadastral Property</rdfs:label>
    <rdfs:label xml:lang="es">Inmueble Catastral</rdfs:label>
    <rdfs:comment xml:lang="en">Real estate property registered in the Cadastre. Can be a premises, dwelling, or any independent use unit within a parcel. A cadastral property may have one or more constructions associated.</rdfs:comment>
    <rdfs:comment xml:lang="es">Bien inmueble inscrito en el Catastro. Puede ser un local, vivienda, o cualquier unidad de uso independiente dentro de una parcela. Un inmueble catastral puede tener una o más construcciones asociadas.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
    <rdfs:subClassOf rdf:nodeID="n0c54e936ab814760b5a795086612e401b3"/>
    <rdfs:subClassOf rdf:nodeID="n0c54e936ab814760b5a795086612e401b4"/>
    <rdfs:subClassOf rdf:nodeID="n0c54e936ab814760b5a795086612e401b5"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralReference">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Cadastral Reference</rdfs:label>
    <rdfs:label xml:lang="es">Referencia Catastral</rdfs:label>
    <rdfs:comment xml:lang="en">Abstract parent class for cadastral reference types.</rdfs:comment>
    <rdfs:comment xml:lang="es">Clase padre abstracta para los tipos de referencia catastral.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasUse">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has use</rdfs:label>
    <rdfs:label xml:lang="es">tiene uso</rdfs:label>
    <rdfs:domain rdf:nodeID="n0c54e936ab814760b5a795086612e401b10"/>
    <rdfs:range rdf:nodeID="n0c54e936ab814760b5a795086612e401b13"/>
    <rdfs:comment xml:lang="en">Relationship that assigns a primary use to a property or construction. Use concepts are defined in the external SKOS vocabulary at http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/uso.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relación que asigna un uso principal a un inmueble o construcción. Los conceptos de uso se definen en el vocabulario SKOS externo en http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/uso.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n0c54e936ab814760b5a795086612e401b14">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
    <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/uso"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/door">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">door</rdfs:label>
    <rdfs:label xml:lang="es">puerta</rdfs:label>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">Door or unit identifier within a floor and staircase.</rdfs:comment>
    <rdfs:comment xml:lang="es">Identificador de puerta o unidad dentro de una planta y escalera.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:versionIRI rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/0.1.0"/>
    <owl:versionInfo>0.1.0</owl:versionInfo>
    <dcterms:title xml:lang="en">Spanish Cadastre Ontology</dcterms:title>
    <dcterms:title xml:lang="es">Ontología del Catastro Español</dcterms:title>
    <dcterms:description xml:lang="en">Ontology for modeling Spanish Cadastre entities, focused on Parcels, Properties and Buildings. Reuses GeoSPARQL, INSPIRE concepts, and the Spanish street catalog (callejero) vocabulary.</dcterms:description>
    <dcterms:description xml:lang="es">Ontología para modelar las entidades del Catastro Español, centrada en Parcelas, Inmuebles y Construcciones. Reutiliza GeoSPARQL, conceptos INSPIRE y el vocabulario de callejero español.</dcterms:description>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-09</dcterms:issued>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-09</dcterms:created>
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-17</dcterms:modified>
    <dcterms:creator>Daniel Doña</dcterms:creator>
    <dcterms:creator>Edna Ruckhaus</dcterms:creator>
    <dcterms:creator>Lucía Sánchez</dcterms:creator>
    <dcterms:creator>Maria del Socorro Bernardos</dcterms:creator>
    <dcterms:creator>Oscar Corcho</dcterms:creator>
    <dcterms:hasFormat rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/ontology.owl"/>
    <dcterms:abstract xml:lang="en">Ontology for modeling Spanish Cadastre core entities (Parcels, Properties, Buildings) with their spatial, administrative, and descriptive attributes.</dcterms:abstract>
    <dcterms:abstract xml:lang="es">Ontología para modelar las entidades core del Catastro Español (Parcelas, Inmuebles, Construcciones) con sus atributos espaciales, administrativos y descriptivos.</dcterms:abstract>
    <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
    <owl:imports rdf:resource="http://www.opengis.net/ont/geosparql"/>
    <owl:imports rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero"/>
    <rdfs:comment xml:lang="en">Initial draft version focusing on core classes: CadastralParcel, CadastralProperty, and CadastralConstruction with their relationships and properties.</rdfs:comment>
    <rdfs:comment xml:lang="es">Versión inicial centrada en las clases principales: ParcelaCatastral, Inmueble y Construcción con sus relaciones y propiedades.</rdfs:comment>
    <vann:preferredNamespaceUri>http://vocab.linkeddata.es/datosabiertos/def/catastro/</vann:preferredNamespaceUri>
    <vann:preferredNamespacePrefix>edintcat</vann:preferredNamespacePrefix>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/propertyReferenceFor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">property reference for</rdfs:label>
    <rdfs:label xml:lang="es">referencia de inmueble para</rdfs:label>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/PropertyReference"/>
    <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
    <rdfs:comment xml:lang="en">Relationship indicating that a property reference identifies a specific cadastral property.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relación que indica que una referencia de inmueble identifica un inmueble catastral específico.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n0c54e936ab814760b5a795086612e401b7">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:unionOf rdf:nodeID="n0c54e936ab814760b5a795086612e401b8"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/staircase">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">staircase</rdfs:label>
    <rdfs:label xml:lang="es">escalera</rdfs:label>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">Staircase identifier for a construction unit within a building.</rdfs:comment>
    <rdfs:comment xml:lang="es">Identificador de escalera para una unidad de construcción dentro de un edificio.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasAddress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has address</rdfs:label>
    <rdfs:label xml:lang="es">tiene dirección</rdfs:label>
    <rdfs:domain rdf:nodeID="n0c54e936ab814760b5a795086612e401b7"/>
    <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Portal"/>
    <rdfs:comment xml:lang="en">Relationship linking a property or parcel to its address in the callejero vocabulary. Through this relationship, location information (municipality, province, postal code) can be obtained from the linked callejero:Portal.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relación que vincula un inmueble o parcela con su dirección en el vocabulario callejero. A través de esta relación, se puede obtener información de ubicación (municipio, provincia, código postal) del Portal enlazado.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/renovationDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">renovation date</rdfs:label>
    <rdfs:label xml:lang="es">fecha de reforma</rdfs:label>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/Renovation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    <rdfs:comment xml:lang="en">Date when the renovation was performed.</rdfs:comment>
    <rdfs:comment xml:lang="es">Fecha en que se realizó la reforma.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n0c54e936ab814760b5a795086612e401b6">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/onCadastralProperty"/>
    <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
    <owl:onClass rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasClass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has class</rdfs:label>
    <rdfs:label xml:lang="es">tiene clase</rdfs:label>
    <rdfs:domain rdf:nodeID="n0c54e936ab814760b5a795086612e401b17"/>
    <rdfs:range rdf:nodeID="n0c54e936ab814760b5a795086612e401b20"/>
    <rdfs:comment xml:lang="en">Relationship that assigns a classification (urban/rural) to a parcel or property. Classification concepts are defined in external SKOS vocabulary at http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/clase.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relación que asigna una clasificación (urbano/rústico) a una parcela o inmueble. Los conceptos de clasificación se definen en el vocabulario SKOS externo en http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/clase.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/parcelReferenceFor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">parcel reference for</rdfs:label>
    <rdfs:label xml:lang="es">referencia de parcela para</rdfs:label>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/ParcelReference"/>
    <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralParcel"/>
    <rdfs:comment xml:lang="en">Relationship indicating that a parcel reference identifies a specific cadastral parcel.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relación que indica que una referencia de parcela identifica una parcela catastral específica.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/onCadastralProperty">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">on cadastral property</rdfs:label>
    <rdfs:label xml:lang="es">en inmueble catastral</rdfs:label>
    <rdfs:comment xml:lang="en">Relationship indicating that a cadastral construction is located on a specific cadastral property.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relación que indica que una construcción catastral está ubicada sobre un inmueble catastral específico.</rdfs:comment>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction"/>
    <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/renovationOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">renovation of</rdfs:label>
    <rdfs:label xml:lang="es">reforma de</rdfs:label>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/Renovation"/>
    <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction"/>
    <rdfs:comment xml:lang="en">Relationship indicating that a renovation event applies to a specific construction.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relación que indica que un evento de reforma se aplica a una construcción específica.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/participation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">participation</rdfs:label>
    <rdfs:label xml:lang="es">participación</rdfs:label>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <qudt:unit rdf:resource="http://qudt.org/vocab/unit/PCT"/>
    <rdfs:comment xml:lang="en">Percentage of participation in common elements of the property.</rdfs:comment>
    <rdfs:comment xml:lang="es">Porcentaje de participación en elementos comunes del inmueble.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/parcelReference">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">parcel reference</rdfs:label>
    <rdfs:label xml:lang="es">referencia de parcela</rdfs:label>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/ParcelReference"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">The 7-character alphanumeric parcel reference code (e.g., 0569302VK).</rdfs:comment>
    <rdfs:comment xml:lang="es">El código alfanumérico de 7 caracteres de la referencia de parcela (ej. 0569302VK).</rdfs:comment>
    <rdfs:seeAlso rdf:resource="https://www.sedecatastro.gob.es"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/ParcelReference">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralReference"/>
    <rdfs:label xml:lang="en">Parcel Reference</rdfs:label>
    <rdfs:label xml:lang="es">Referencia de Parcela</rdfs:label>
    <rdfs:comment xml:lang="en">Reference identifying a cadastral parcel (7-character alphanumeric code).</rdfs:comment>
    <rdfs:comment xml:lang="es">Referencia que identifica una parcela catastral (código alfanumérico de 7 caracteres).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasRenovation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has renovation</rdfs:label>
    <rdfs:label xml:lang="es">tiene reforma</rdfs:label>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction"/>
    <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/Renovation"/>
    <rdfs:comment xml:lang="en">Relationship indicating that a construction has undergone one or more renovation events.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relación que indica que una construcción ha sufrido una o más reformas.</rdfs:comment>
    <owl:inverseOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/renovationOf"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n0c54e936ab814760b5a795086612e401b22">
