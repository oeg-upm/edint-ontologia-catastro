@prefix : <http://vocab.linkeddata.es/datosabiertos/def/catastro/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://vocab.linkeddata.es/datosabiertos/def/catastro/> .

<http://vocab.linkeddata.es/datosabiertos/def/catastro/> rdf:type owl:Ontology ;
                                                          owl:versionIRI <http://vocab.linkeddata.es/datosabiertos/def/catastro/0.1.0> ;
                                                          owl:imports <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero> ,
                                                                      <http://www.opengis.net/ont/geosparql> ;
                                                          <http://purl.org/dc/terms/abstract> "Ontology for modeling Spanish Cadastre core entities (Parcels, Properties, Buildings) with their spatial, administrative, and descriptive attributes."@en ,
                                                                                              "Ontología para modelar las entidades core del Catastro Español (Parcelas, Inmuebles, Construcciones) con sus atributos espaciales, administrativos y descriptivos."@es ;
                                                          <http://purl.org/dc/terms/created> "2026-04-09"^^xsd:date ;
                                                          <http://purl.org/dc/terms/creator> "Daniel Doña"@es ,
                                                                                             "Edna Ruckhaus" ,
                                                                                             "Lucía Sánchez" ,
                                                                                             "Maria del Socorro Bernardos" ,
                                                                                             "Oscar Corcho" ;
                                                          <http://purl.org/dc/terms/description> "Ontology for modeling Spanish Cadastre entities, focused on Parcels, Properties and Buildings. Reuses GeoSPARQL, INSPIRE concepts, and the Spanish street catalog (callejero) vocabulary."@en ,
                                                                                                 "Ontología para modelar las entidades del Catastro Español, centrada en Parcelas, Inmuebles y Construcciones. Reutiliza GeoSPARQL, conceptos INSPIRE y el vocabulario de callejero español."@es ;
                                                          <http://purl.org/dc/terms/hasFormat> :ontology.owl ;
                                                          <http://purl.org/dc/terms/issued> "2026-04-09"^^xsd:date ;
                                                          <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                                          <http://purl.org/dc/terms/modified> "2026-04-09"^^xsd:date ;
                                                          <http://purl.org/dc/terms/title> "Ontología del Catastro Español"@es ,
                                                                                           "Spanish Cadastre Ontology"@en ;
                                                          <http://purl.org/vocab/vann/preferredNamespacePrefix> "edintcat" ;
                                                          <http://purl.org/vocab/vann/preferredNamespaceUri> "http://vocab.linkeddata.es/datosabiertos/def/catastro/" ;
                                                          rdfs:comment "Initial draft version focusing on core classes: CadastralParcel, CadastralProperty, and CadastralConstruction with their relationships and properties."@en ,
                                                                       "Versión inicial centrada en las clases principales: ParcelaCatastral, Inmueble y Construcción con sus relaciones y propiedades."@es ;
                                                          owl:versionInfo "0.1.0" .

