    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/Renovation">
        <rdfs:comment xml:lang="en">Event or process of renovating a construction, including information about when it occurred and what type of renovation was performed.</rdfs:comment>
        <rdfs:comment xml:lang="es">Evento o proceso de reforma de una construcción, incluyendo información sobre cuándo ocurrió y qué tipo de reforma se realizó.</rdfs:comment>
        <rdfs:label xml:lang="es">Reforma</rdfs:label>
        <rdfs:label xml:lang="en">Renovation</rdfs:label>
    </owl:Class>
    


