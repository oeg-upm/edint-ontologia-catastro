<?xml version="1.0"?>
<rdf:RDF xmlns="http://vocab.linkeddata.es/datosabiertos/def/catastro/"
     xml:base="http://vocab.linkeddata.es/datosabiertos/def/catastro/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:ns="http://creativecommons.org/ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:qudt="http://qudt.org/schema/qudt/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/">
        <owl:versionIRI rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/0.1.0"/>
        <owl:imports rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero"/>
        <owl:imports rdf:resource="http://www.opengis.net/ont/geosparql"/>
        <terms:abstract xml:lang="en">Ontology for modeling Spanish Cadastre core entities (Parcels, Properties, Buildings) with their spatial, administrative, and descriptive attributes.</terms:abstract>
        <terms:abstract xml:lang="es">Ontología para modelar las entidades core del Catastro Español (Parcelas, Inmuebles, Construcciones) con sus atributos espaciales, administrativos y descriptivos.</terms:abstract>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-09</terms:created>
        <terms:creator>Daniel Doña</terms:creator>
        <terms:creator>Edna Ruckhaus</terms:creator>
        <terms:creator>Lucía Sánchez</terms:creator>
        <terms:creator>Maria del Socorro Bernardos</terms:creator>
        <terms:creator>Oscar Corcho</terms:creator>
        <terms:description xml:lang="en">Ontology for modeling Spanish Cadastre entities, focused on Parcels, Properties and Buildings. Reuses GeoSPARQL, INSPIRE concepts, and the Spanish street catalog (callejero) vocabulary.</terms:description>
        <terms:description xml:lang="es">Ontología para modelar las entidades del Catastro Español, centrada en Parcelas, Inmuebles y Construcciones. Reutiliza GeoSPARQL, conceptos INSPIRE y el vocabulario de callejero español.</terms:description>
        <terms:hasFormat rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/ontology.owl"/>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-09</terms:issued>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-17</terms:modified>
        <terms:title xml:lang="es">Ontología del Catastro Español</terms:title>
        <terms:title xml:lang="en">Spanish Cadastre Ontology</terms:title>
        <vann:preferredNamespacePrefix>edintcat</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>http://vocab.linkeddata.es/datosabiertos/def/catastro/</vann:preferredNamespaceUri>
        <rdfs:comment xml:lang="en">Initial draft version focusing on core classes: CadastralParcel, CadastralProperty, and CadastralConstruction with their relationships and properties.</rdfs:comment>
        <rdfs:comment xml:lang="es">Versión inicial centrada en las clases principales: ParcelaCatastral, Inmueble y Construcción con sus relaciones y propiedades.</rdfs:comment>
        <owl:versionInfo>0.1.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/abstract -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/abstract"/>
    


    <!-- http://purl.org/dc/terms/created -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/created"/>
    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/modified -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/modified"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://qudt.org/schema/qudt/unit -->


    <owl:AnnotationProperty rdf:about="http://qudt.org/schema/qudt/unit"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#gYear -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#gYear"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/hasAddress -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasAddress">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralParcel"/>
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Portal"/>
        <rdfs:comment xml:lang="es">Relación que vincula un inmueble o parcela con su dirección en el vocabulario callejero. A través de esta relación, se puede obtener información de ubicación (municipio, provincia, código postal) del Portal enlazado.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship linking a property or parcel to its address in the callejero vocabulary. Through this relationship, location information (municipality, province, postal code) can be obtained from the linked callejero:Portal.</rdfs:comment>
        <rdfs:label xml:lang="en">has address</rdfs:label>
        <rdfs:label xml:lang="es">tiene dirección</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/hasCadastralConstruction -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasCadastralConstruction">
        <owl:inverseOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/onCadastralProperty"/>
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction"/>
        <rdfs:comment xml:lang="es">Relación que indica las unidades constructivas específicas (locales/partes) que conforman un inmueble catastral.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship indicating the specific constructive units (locales/parts) that make up a cadastral property.</rdfs:comment>
        <rdfs:label xml:lang="en">has cadastral construction</rdfs:label>
        <rdfs:label xml:lang="es">tiene construcción catastral</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/hasCadastralProperty -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasCadastralProperty">
        <owl:inverseOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/onCadastralParcel"/>
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralParcel"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
        <rdfs:comment xml:lang="es">Relación que indica que una parcela catastral contiene uno o más inmuebles catastrales (ej. pisos en una división horizontal).</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship indicating that a cadastral parcel contains one or more cadastral properties (e.g., flats in a horizontal division).</rdfs:comment>
        <rdfs:label xml:lang="en">has cadastral property</rdfs:label>
        <rdfs:label xml:lang="es">tiene inmueble catastral</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/hasClass -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasClass">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralParcel"/>
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/clase"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Relación que asigna una clasificación (urbano/rústico) a una parcela o inmueble. Los conceptos de clasificación se definen en el vocabulario SKOS externo en http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/clase.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship that assigns a classification (urban/rural) to a parcel or property. Classification concepts are defined in external SKOS vocabulary at http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/clase.</rdfs:comment>
        <rdfs:label xml:lang="en">has class</rdfs:label>
        <rdfs:label xml:lang="es">tiene clase</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/hasParcelReference -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasParcelReference">
        <owl:inverseOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/parcelReferenceFor"/>
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralParcel"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/ParcelReference"/>
        <rdfs:comment xml:lang="es">Relación que vincula una parcela catastral con su referencia de parcela.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship linking a cadastral parcel to its parcel reference.</rdfs:comment>
        <rdfs:label xml:lang="en">has parcel reference</rdfs:label>
        <rdfs:label xml:lang="es">tiene referencia de parcela</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/hasPropertyReference -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasPropertyReference">
        <owl:inverseOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/propertyReferenceFor"/>
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/PropertyReference"/>
        <rdfs:comment xml:lang="es">Relación que vincula un inmueble catastral con su referencia de inmueble.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship linking a cadastral property to its property reference.</rdfs:comment>
        <rdfs:label xml:lang="en">has property reference</rdfs:label>
        <rdfs:label xml:lang="es">tiene referencia de inmueble</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/hasRenovation -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasRenovation">
        <owl:inverseOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/renovationOf"/>
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/Renovation"/>
        <rdfs:comment xml:lang="es">Relación que indica que una construcción ha sufrido una o más reformas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship indicating that a construction has undergone one or more renovation events.</rdfs:comment>
        <rdfs:label xml:lang="en">has renovation</rdfs:label>
        <rdfs:label xml:lang="es">tiene reforma</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/hasUse -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasUse">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction"/>
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/uso"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Relación que asigna un uso principal a un inmueble o construcción. Los conceptos de uso se definen en el vocabulario SKOS externo en http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/uso.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship that assigns a primary use to a property or construction. Use concepts are defined in the external SKOS vocabulary at http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/uso.</rdfs:comment>
        <rdfs:label xml:lang="en">has use</rdfs:label>
        <rdfs:label xml:lang="es">tiene uso</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/onCadastralParcel -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/onCadastralParcel">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralParcel"/>
        <rdfs:comment xml:lang="es">Relación que indica que un inmueble catastral está ubicado sobre una única parcela catastral.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship indicating that a cadastral property is located on exactly one cadastral parcel.</rdfs:comment>
        <rdfs:label xml:lang="en">on cadastral parcel</rdfs:label>
        <rdfs:label xml:lang="es">sobre parcela catastral</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/onCadastralProperty -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/onCadastralProperty">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
        <rdfs:comment xml:lang="es">Relación que indica que una construcción catastral está ubicada sobre un inmueble catastral específico.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship indicating that a cadastral construction is located on a specific cadastral property.</rdfs:comment>
        <rdfs:label xml:lang="es">en inmueble catastral</rdfs:label>
        <rdfs:label xml:lang="en">on cadastral property</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/parcelReferenceFor -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/parcelReferenceFor">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/ParcelReference"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralParcel"/>
        <rdfs:comment xml:lang="es">Relación que indica que una referencia de parcela identifica una parcela catastral específica.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship indicating that a parcel reference identifies a specific cadastral parcel.</rdfs:comment>
        <rdfs:label xml:lang="en">parcel reference for</rdfs:label>
        <rdfs:label xml:lang="es">referencia de parcela para</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/propertyReferenceFor -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/propertyReferenceFor">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/PropertyReference"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
        <rdfs:comment xml:lang="es">Relación que indica que una referencia de inmueble identifica un inmueble catastral específico.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship indicating that a property reference identifies a specific cadastral property.</rdfs:comment>
        <rdfs:label xml:lang="en">property reference for</rdfs:label>
        <rdfs:label xml:lang="es">referencia de inmueble para</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/renovationOf -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/renovationOf">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/Renovation"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction"/>
        <rdfs:comment xml:lang="es">Relación que indica que un evento de reforma se aplica a una construcción específica.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship indicating that a renovation event applies to a specific construction.</rdfs:comment>
        <rdfs:label xml:lang="es">reforma de</rdfs:label>
        <rdfs:label xml:lang="en">renovation of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#hasGeometry -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#hasGeometry"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/constructionYear -->


    <owl:DatatypeProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/constructionYear">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
        <rdfs:comment xml:lang="es">Año en que se construyó el edificio.</rdfs:comment>
        <rdfs:comment xml:lang="en">Year in which the building was constructed.</rdfs:comment>
        <rdfs:label xml:lang="es">año de construcción</rdfs:label>
        <rdfs:label xml:lang="en">construction year</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/door -->


    <owl:DatatypeProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/door">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Door or unit identifier within a floor and staircase.</rdfs:comment>
        <rdfs:comment xml:lang="es">Identificador de puerta o unidad dentro de una planta y escalera.</rdfs:comment>
        <rdfs:label xml:lang="en">door</rdfs:label>
        <rdfs:label xml:lang="es">puerta</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/floor -->


    <owl:DatatypeProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/floor">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Floor level identifier for a construction unit (can include basement levels like -1, -2).</rdfs:comment>
        <rdfs:comment xml:lang="es">Identificador de planta para una unidad de construcción (puede incluir plantas sótano como -1, -2).</rdfs:comment>
        <rdfs:label xml:lang="en">floor</rdfs:label>
        <rdfs:label xml:lang="es">planta</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/hasHorizontalDivision -->


    <owl:DatatypeProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasHorizontalDivision">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Boolean indicating whether a cadastral property is subject to horizontal division regime.</rdfs:comment>
        <rdfs:comment xml:lang="es">Booleano que indica si un inmueble catastral está sujeto a régimen de división horizontal.</rdfs:comment>
        <rdfs:label xml:lang="en">has horizontal division</rdfs:label>
        <rdfs:label xml:lang="es">tiene división horizontal</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/parcelReference -->


    <owl:DatatypeProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/parcelReference">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/ParcelReference"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">El código alfanumérico de 7 caracteres de la referencia de parcela (ej. 0569302VK).</rdfs:comment>
        <rdfs:comment xml:lang="en">The 7-character alphanumeric parcel reference code (e.g., 0569302VK).</rdfs:comment>
        <rdfs:label xml:lang="en">parcel reference</rdfs:label>
