    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/onCadastralProperty"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Building or construction registered on a cadastral property. Includes data on area, use, construction characteristics, and renovations. A cadastral construction is located on exactly one cadastral property.</rdfs:comment>
        <rdfs:comment xml:lang="es">Edificio o construcción registrada sobre un inmueble catastral. Incluye datos de superficie, uso, características constructivas y reformas. Una construcción catastral está ubicada sobre un único inmueble catastral.</rdfs:comment>
        <rdfs:label xml:lang="en">Cadastral Construction</rdfs:label>
        <rdfs:label xml:lang="es">Construcción Catastral</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralParcel -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralParcel">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.opengis.net/ont/geosparql#hasGeometry"/>
                <owl:someValuesFrom rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasParcelReference"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/ParcelReference"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Basic unit of territorial division in the Spanish Cadastre. Represents a plot of land delimited geographically, which may contain one or more properties.</rdfs:comment>
        <rdfs:comment xml:lang="es">Unidad básica de división territorial en el Catastro Español. Representa una porción de terreno delimitada geográficamente, que puede contener uno o más inmuebles.</rdfs:comment>
        <rdfs:label xml:lang="en">Cadastral Parcel</rdfs:label>
        <rdfs:label xml:lang="es">Parcela Catastral</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasCadastralConstruction"/>
                <owl:someValuesFrom rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/hasPropertyReference"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/PropertyReference"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/onCadastralParcel"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralParcel"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Bien inmueble inscrito en el Catastro. Puede ser un local, vivienda, o cualquier unidad de uso independiente dentro de una parcela. Un inmueble catastral puede tener una o más construcciones asociadas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Real estate property registered in the Cadastre. Can be a premises, dwelling, or any independent use unit within a parcel. A cadastral property may have one or more constructions associated.</rdfs:comment>
        <rdfs:label xml:lang="en">Cadastral Property</rdfs:label>
        <rdfs:label xml:lang="es">Inmueble Catastral</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralReference -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralReference">
        <rdfs:comment xml:lang="en">Abstract parent class for cadastral reference types.</rdfs:comment>
        <rdfs:comment xml:lang="es">Clase padre abstracta para los tipos de referencia catastral.</rdfs:comment>
        <rdfs:label xml:lang="en">Cadastral Reference</rdfs:label>
        <rdfs:label xml:lang="es">Referencia Catastral</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/ParcelReference -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/ParcelReference">
        <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralReference"/>
        <rdfs:comment xml:lang="en">Reference identifying a cadastral parcel (7-character alphanumeric code).</rdfs:comment>
        <rdfs:comment xml:lang="es">Referencia que identifica una parcela catastral (código alfanumérico de 7 caracteres).</rdfs:comment>
        <rdfs:label xml:lang="en">Parcel Reference</rdfs:label>
        <rdfs:label xml:lang="es">Referencia de Parcela</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/PropertyReference -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/PropertyReference">
        <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralReference"/>
        <rdfs:comment xml:lang="en">Reference identifying a cadastral property, composed of the parcel reference and the property reference with check digit (e.g., TF8006N0001HZ).</rdfs:comment>
        <rdfs:comment xml:lang="es">Referencia que identifica un inmueble catastral, compuesta por la referencia de parcela y la referencia de inmueble con dígito de control (ej. TF8006N0001HZ).</rdfs:comment>
        <rdfs:label xml:lang="en">Property Reference</rdfs:label>
        <rdfs:label xml:lang="es">Referencia de Inmueble</rdfs:label>
    </owl:Class>
    


