}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/catastro/",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/abstract" : [ {
    "@language" : "en",
    "@value" : "Ontology for modeling Spanish Cadastre core entities (Parcels, Properties, Buildings) with their spatial, administrative, and descriptive attributes."
  }, {
    "@language" : "es",
    "@value" : "Ontología para modelar las entidades core del Catastro Español (Parcelas, Inmuebles, Construcciones) con sus atributos espaciales, administrativos y descriptivos."
  } ],
  "http://purl.org/dc/terms/created" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-04-09"
  } ],
  "http://purl.org/dc/terms/creator" : [ {
    "@value" : "Daniel Doña"
  }, {
    "@value" : "Edna Ruckhaus"
  }, {
    "@value" : "Lucía Sánchez"
  }, {
    "@value" : "Maria del Socorro Bernardos"
  }, {
    "@value" : "Oscar Corcho"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "Ontology for modeling Spanish Cadastre entities, focused on Parcels, Properties and Buildings. Reuses GeoSPARQL, INSPIRE concepts, and the Spanish street catalog (callejero) vocabulary."
  }, {
    "@language" : "es",
    "@value" : "Ontología para modelar las entidades del Catastro Español, centrada en Parcelas, Inmuebles y Construcciones. Reutiliza GeoSPARQL, conceptos INSPIRE y el vocabulario de callejero español."
  } ],
  "http://purl.org/dc/terms/hasFormat" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/catastro/ontology.owl"
  } ],
  "http://purl.org/dc/terms/issued" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-04-09"
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@id" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/dc/terms/modified" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-04-17"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@language" : "es",
    "@value" : "Ontología del Catastro Español"
  }, {
    "@language" : "en",
    "@value" : "Spanish Cadastre Ontology"
  } ],
  "http://purl.org/vocab/vann/preferredNamespacePrefix" : [ {
    "@value" : "edintcat"
  } ],
  "http://purl.org/vocab/vann/preferredNamespaceUri" : [ {
    "@value" : "http://vocab.linkeddata.es/datosabiertos/def/catastro/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Initial draft version focusing on core classes: CadastralParcel, CadastralProperty, and CadastralConstruction with their relationships and properties."
  }, {
    "@language" : "es",
    "@value" : "Versión inicial centrada en las clases principales: ParcelaCatastral, Inmueble y Construcción con sus relaciones y propiedades."
  } ],
  "http://www.w3.org/2002/07/owl#imports" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero"
  }, {
    "@id" : "http://www.opengis.net/ont/geosparql"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/catastro/0.1.0"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "0.1.0"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Building or construction registered on a cadastral property. Includes data on area, use, construction characteristics, and renovations. A cadastral construction is located on exactly one cadastral property."
  }, {
    "@language" : "es",
    "@value" : "Edificio o construcción registrada sobre un inmueble catastral. Incluye datos de superficie, uso, características constructivas y reformas. Una construcción catastral está ubicada sobre un único inmueble catastral."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Cadastral Construction"
  }, {
    "@language" : "es",
    "@value" : "Construcción Catastral"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.opengis.net/ont/geosparql#Feature"
  }, {
    "@id" : "_:genid18"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralParcel",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Basic unit of territorial division in the Spanish Cadastre. Represents a plot of land delimited geographically, which may contain one or more properties."
  }, {
    "@language" : "es",
    "@value" : "Unidad básica de división territorial en el Catastro Español. Representa una porción de terreno delimitada geográficamente, que puede contener uno o más inmuebles."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Cadastral Parcel"
  }, {
    "@language" : "es",
    "@value" : "Parcela Catastral"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.opengis.net/ont/geosparql#Feature"
  }, {
    "@id" : "_:genid19"
  }, {
    "@id" : "_:genid20"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Bien inmueble inscrito en el Catastro. Puede ser un local, vivienda, o cualquier unidad de uso independiente dentro de una parcela. Un inmueble catastral puede tener una o más construcciones asociadas."
  }, {
    "@language" : "en",
    "@value" : "Real estate property registered in the Cadastre. Can be a premises, dwelling, or any independent use unit within a parcel. A cadastral property may have one or more constructions associated."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Cadastral Property"
  }, {
    "@language" : "es",
    "@value" : "Inmueble Catastral"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.opengis.net/ont/geosparql#Feature"
  }, {
    "@id" : "_:genid21"
  }, {
    "@id" : "_:genid22"
  }, {
    "@id" : "_:genid23"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralReference",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Abstract parent class for cadastral reference types."
  }, {
    "@language" : "es",
    "@value" : "Clase padre abstracta para los tipos de referencia catastral."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Cadastral Reference"
  }, {
    "@language" : "es",
    "@value" : "Referencia Catastral"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/catastro/ParcelReference",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Reference identifying a cadastral parcel (7-character alphanumeric code)."
  }, {
    "@language" : "es",
    "@value" : "Referencia que identifica una parcela catastral (código alfanumérico de 7 caracteres)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Parcel Reference"
  }, {
    "@language" : "es",
    "@value" : "Referencia de Parcela"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralReference"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/catastro/PropertyReference",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Reference identifying a cadastral property, composed of the parcel reference and the property reference with check digit (e.g., TF8006N0001HZ)."
  }, {
    "@language" : "es",
    "@value" : "Referencia que identifica un inmueble catastral, compuesta por la referencia de parcela y la referencia de inmueble con dígito de control (ej. TF8006N0001HZ)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Property Reference"
  }, {
    "@language" : "es",
    "@value" : "Referencia de Inmueble"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralReference"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/catastro/Renovation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Event or process of renovating a construction, including information about when it occurred and what type of renovation was performed."
  }, {
    "@language" : "es",
    "@value" : "Evento o proceso de reforma de una construcción, incluyendo información sobre cuándo ocurrió y qué tipo de reforma se realizó."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Reforma"
  }, {
    "@language" : "en",
    "@value" : "Renovation"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/catastro/constructionYear",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Año en que se construyó el edificio."
  }, {
    "@language" : "en",
    "@value" : "Year in which the building was constructed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "año de construcción"
  }, {
    "@language" : "en",
    "@value" : "construction year"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#gYear"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/catastro/door",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Door or unit identifier within a floor and staircase."
  }, {
    "@language" : "es",
    "@value" : "Identificador de puerta o unidad dentro de una planta y escalera."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "door"
  }, {
    "@language" : "es",
    "@value" : "puerta"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#string"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/catastro/floor",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Floor level identifier for a construction unit (can include basement levels like -1, -2)."
  }, {
    "@language" : "es",
    "@value" : "Identificador de planta para una unidad de construcción (puede incluir plantas sótano como -1, -2)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralConstruction"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "floor"
  }, {
    "@language" : "es",
    "@value" : "planta"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#string"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/catastro/hasAddress",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Relación que vincula un inmueble o parcela con su dirección en el vocabulario callejero. A través de esta relación, se puede obtener información de ubicación (municipio, provincia, código postal) del Portal enlazado."
