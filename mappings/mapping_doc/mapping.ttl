@prefix edintcat: <http://vocab.linkeddata.es/datosabiertos/def/catastro#>.
@prefix callejero: <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#>.
@prefix edintkos-clase: <http://vocab.linkeddata.es/datosabiertos/kos/edint/clase/>.
@prefix edintkos-uso: <http://vocab.linkeddata.es/datosabiertos/kos/edint/uso/>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix dct: <http://purl.org/dc/terms/>.
@prefix geo: <http://www.opengis.net/ont/geosparql#>.
@prefix qudt: <http://qudt.org/schema/qudt/>.
@prefix qudtunit: <http://qudt.org/vocab/unit/>.
@prefix rr: <http://www.w3.org/ns/r2rml#>.
@prefix rml: <http://semweb.mmlab.be/ns/rml#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix ql: <http://semweb.mmlab.be/ns/ql#>.
@prefix d2rq: <http://www.wiwiss.fu-berlin.de/suhl/bizer/D2RQ/0.1#>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix schema: <http://schema.org/>.
@prefix formats: <http://www.w3.org/ns/formats/>.
@prefix comp: <http://semweb.mmlab.be/ns/rml-compression#>.
@prefix void: <http://rdfs.org/ns/void#>.
@prefix fnml: <http://semweb.mmlab.be/ns/fnml#>.
@prefix grel: <http://users.ugent.be/~bjdmeest/function/grel.ttl#>.
@base <http://example.com/ns#>.
@prefix map: <http://mapping.example.com/resource/> .

map:person_000 a foaf:Person ;
    rdfs:label "Jhon Toledo" ;
    foaf:mbox <mailto:ja.toledo@upm.es> .

map:rules_000 schema:contributor map:person_000 ;
    rdf:type schema:Dataset ;
    schema:version "1.0.0" ;
    schema:title "Mappings RML para transformar datos catastrales a RDF (Ontología EDINT Catastro)" ;
    schema:dateCreated "20-04-2026" ;
    schema:description "Este conjunto de mappings RML transforma datos catastrales a RDF, utilizando la ontología EDINT Catastro. El objetivo es generar un grafo RDF interoperable para representar parcelas catastrales, inmuebles, construcciones, referencias catastrales y direcciones asociadas, facilitando su reutilización e integración en sistemas semánticos." .

<parcela_catastral_0> a rr:TriplesMap;

	rml:logicalSource [
		a rml:LogicalSource;
		rml:source "inmuebles.csv";
		rml:referenceFormulation ql:CSV

	];
	rr:subjectMap [
		a rr:SubjectMap;
		rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/Parcela_{parcel_ref}";
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant rdf:type;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:constant edintcat:CadastralParcel;
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant rdfs:label;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "parcel_label";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant edintcat:hasCadastralProperty;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/Inmueble_{property_ref}";
			rr:termType rr:IRI
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant edintcat:hasCadastralReference;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/referencia-catastral/Ref_Parcela_{parcel_ref}";
			rr:termType rr:IRI
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant edintcat:hasAddress;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/portal/{portal_id}";
			rr:termType rr:IRI
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant dct:source;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "source_url";
			rr:datatype xsd:anyURI
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant geo:hasGeometry;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/geometria/parcela/{parcel_ref}";
			rr:termType rr:IRI
		];
	].


